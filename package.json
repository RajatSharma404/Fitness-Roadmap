{
  "name": "fitness-roadmap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:api": "ts-node --project tsconfig.server.json src/server/index.ts",
    "build": "next build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "next start -p 3001",
    "start:api": "ts-node --transpile-only --project tsconfig.server.json src/server/index.ts",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --project tsconfig.server.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "pm2:start": "pm2 start pm2.config.js",
    "pm2:stop": "pm2 stop pm2.config.js",
    "pm2:restart": "pm2 restart pm2.config.js",
    "pm2:delete": "pm2 delete pm2.config.js",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.16.3",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^12.38.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.0.1",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "next": "^15.5.14",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.16.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
